{
  "name": "Interactive Button",
  "description": "Button with click event",
  "messages": [
    {
      "version": "v0.10",
      "createSurface": {
        "surfaceId": "example_3",
        "catalogId": "https://a2ui.org/specification/v0_10/catalogs/minimal/catalog.json"
      }
    },
    {
      "version": "v0.10",
      "updateComponents": {
        "surfaceId": "example_3",
        "components": [
          {
            "id": "root",
            "component": "Column",
            "children": ["title", "action_button"],
            "justify": "center",
            "align": "center"
          },
          {
            "id": "title",
            "component": "Text",
            "text": "Click the button below",
            "variant": "body"
          },
          {
            "id": "action_button",
            "component": "Button",
            "child": "button_label",
            "variant": "primary",
            "action": {
              "event": {
                "name": "button_clicked",
                "context": {}
              }
            }
          },
          {
            "id": "button_label",
            "component": "Text",
            "text": "Click Me"
          }
        ]
      }
    }
  ]
}
